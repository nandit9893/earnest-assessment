{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",

    "module": "node16",
    "moduleResolution": "node16",
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "types": ["node"],

    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "resolveJsonModule": true
  }
}